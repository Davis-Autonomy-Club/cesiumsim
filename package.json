{
  "name": "cesiumsim",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "benchmark:smoke": "rm -rf .benchmark-smoke && mkdir -p .benchmark-smoke && printf '{\"type\":\"commonjs\"}\n' > .benchmark-smoke/package.json && tsc -p tsconfig.smoke.json && node .benchmark-smoke/evaluation/smoke-benchmark.js",
    "benchmark:smoke": "rm -rf .benchmark-smoke && mkdir -p .benchmark-smoke && printf '{\"type\":\"commonjs\"}\n' > .benchmark-smoke/package.json && tsc -p tsconfig.smoke.json && node .benchmark-smoke/evaluation/smoke-benchmark.js",
    "dev:security": "vite --open /security-dashboard.html",
    "wyze:up": "docker compose -f security/wyze-bridge/docker-compose.yml up -d",
    "wyze:logs": "docker compose -f security/wyze-bridge/docker-compose.yml logs -f --tail=120",
    "wyze:down": "docker compose -f security/wyze-bridge/docker-compose.yml down",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@takram/three-atmosphere": "^0.16.0",
    "@takram/three-clouds": "^0.6.0",
    "@takram/three-geospatial": "^0.6.0",
    "@takram/three-geospatial-effects": "^0.5.0",
    "astronomy-engine": "^2.1.19",
    "hls.js": "^1.6.15",
    "postprocessing": "^6.38.2",
    "simplex-noise": "^4.0.3",
    "three": "^0.182.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
