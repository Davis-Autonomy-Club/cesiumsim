#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/robots/bitcraze/crazyflie/protos/Crazyflie.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/trees/protos/Pine.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/trees/protos/Oak.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/trees/protos/Cypress.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/trees/protos/BigSassafras.proto"

WorldInfo {
  title "Benchmark 3: Correct Firefighter Identification"
  basicTimeStep 2
  FPS 20
}

# ── COORDINATE REFERENCE (for concurrent_metrics.py) ────────────────────────
# Drone start:          (0, 0, 0)
# Team Alpha (RED):     x=10, y=70  <-- CORRECT TARGET
# Team Bravo (BLUE):    x=70, y=10  <-- DISTRACTOR
# concurrent_metrics:
#   ALPHA = (10, 70)
#   BRAVO = (70, 10)
#   correct_target radius: 5m
#   wrong_target_approached radius: 20m
# ─────────────────────────────────────────────────────────────────────────────

Viewpoint {
  orientation -0.2 0.4 0.9 1.2
  position 10 -15 30
  follow "Crazyflie"
  followSmoothness 0.01
}

TexturedBackground {
}

TexturedBackgroundLight {
}

# Ground - Forest floor
DEF GROUND Solid {
  translation 0 0 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.4 0.35 0.25
        roughness 0.9
        metalness 0
        baseColorMap ImageTexture {
          url [
            "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/vehicles/worlds/textures/ground.jpg"
          ]
        }
        textureTransform TextureTransform {
          scale 100 100
        }
      }
      geometry DEF GROUND_PLANE Plane {
        size 300 300
      }
    }
  ]
  boundingObject USE GROUND_PLANE
  locked TRUE
}

# DRONE
Crazyflie {
  rotation 0 0 1 -1.57079632679
  controller "ardupilot_vehicle_controller"
  controllerArgs [
    "--motors"
    "m1_motor, m3_motor, m4_motor, m2_motor"
    "--reversed-motors"
    "1, 2"
    "--camera-fps"
    "10"
    "--camera"
    "camera"
    "--camera-port"
    "5599"
    "--accel"
    "accelerometer"
    "--imu"
    "inertial unit"
    "--gyro"
    "gyro"
    "--gps"
    "gps"
    "--motor-cap"
    "100"
  ]
  extensionSlot [
    Accelerometer {
    }
  ]
}

# BASE CAMP - at origin


# BASE MARKER - Yellow crate


# ── TEAM ALPHA ZONE (CORRECT TARGET) - RED ───────────────────────────────────
# Position: x=10, y=70
Solid {
  translation 10 70 0.01
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.45 0.38 0.28
        roughness 0.95
        metalness 0
      }
      geometry Cylinder {
        height 0.02
        radius 12
      }
    }
  ]
  name "team_alpha_clearing"
}

# Team Alpha tall RED marker tower - made tall so it's visible from a distance
Solid {
  translation 10 70 4
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.9 0.08 0.08
        roughness 0.3
        metalness 0.1
      }
      geometry Box {
        size 2 2 8
      }
    }
  ]
  name "team_alpha_marker_red"
  boundingObject Box {
    size 2 2 8
  }
  physics Physics {
    density -1
    mass 30
  }
}

# Red flag on top
Solid {
  translation 10 70 8.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.95 0.05 0.05
        roughness 0.4
        metalness 0
      }
      geometry Box {
        size 4 0.1 2.5
      }
    }
  ]
  name "team_alpha_flag_red"
}

# ── TEAM BRAVO ZONE (DISTRACTOR) - BLUE ──────────────────────────────────────
# Position: x=70, y=10
Solid {
  translation 70 10 0.01
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.38 0.42 0.5
        roughness 0.95
        metalness 0
      }
      geometry Cylinder {
        height 0.02
        radius 12
      }
    }
  ]
  name "team_bravo_clearing"
}

