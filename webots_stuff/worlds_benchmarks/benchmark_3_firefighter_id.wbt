Solid {
  translation 70 10 4
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.08 0.25 0.9
        roughness 0.3
        metalness 0.1
      }
      geometry Box {
        size 2 2 8
      }
    }
  ]
  name "team_bravo_marker_blue"
  boundingObject Box {
    size 2 2 8
  }
  physics Physics {
    density -1
    mass 30
  }
}

# Blue flag on top
Solid {
  translation 70 10 8.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.05 0.2 0.95
        roughness 0.4
        metalness 0
      }
      geometry Box {
        size 4 0.1 2.5
      }
    }
  ]
  name "team_bravo_flag_blue"
